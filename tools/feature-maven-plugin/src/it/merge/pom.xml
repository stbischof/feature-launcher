<project xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.eclipse.osgi-technology.featurelauncher-feature-maven-plugin-examples</groupId>
  <artifactId>merge-test</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <build>
    <plugins>
      <plugin>
        <groupId>org.eclipse.osgi-technology.featurelauncher.tools</groupId>
        <artifactId>feature-maven-plugin</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <executions>
          <execution>
            <id>merge-features</id>
            <phase>package</phase>
            <goals>
              <goal>merge-feature</goal>
            </goals>
            <configuration>
              <targetFeature>${project.basedir}/src/main/resources/base-feature.json</targetFeature>
              <mergeFeatures>
                <mergeFeature>${project.basedir}/src/main/resources/merge-source.json</mergeFeature>
              </mergeFeatures>
              <mergeOutputFile>${project.build.directory}/merged-feature.json</mergeOutputFile>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
