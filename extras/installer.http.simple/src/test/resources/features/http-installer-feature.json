{
  "id": "org.eclipse.osgi.technology.featurelauncher.extras:http-installer-feature:1.0.0-SNAPSHOT",
  "name": "Feature HTTP Installer",
  "complete": true,
  "bundles": [
    { "id": "org.eclipse.osgi-technology.featurelauncher.extras:installer.http.simple:1.0.0-SNAPSHOT" }
  ],
  "extensions": {
    "framework-launching-properties": {
      "kind": "mandatory",
      "type": "json",
      "json": {
        "osgi.technology.featurelauncher.extras.installer.http.simple.features.url": "https://example.com/features.json?node={serverId}",
        "osgi.technology.featurelauncher.extras.installer.http.simple.repo.dir": "/app/storage/repo",
        "osgi.technology.featurelauncher.extras.installer.http.simple.scan.mode": "ONCE",
        "osgi.technology.featurelauncher.extras.installer.http.simple.server.id": "my-custom-server-id"
      }
    }
  }
}
